# fitbit-warehouse configuration
# Copy to .env and fill in. NEVER commit .env.

# --- Database connection -----------------------------------------------------
# Standalone mode: leave PG_HOST=db and start the bundled DB with
#   docker compose --profile standalone up -d
# Shared-cluster mode: point PG_HOST at your TimescaleDB host (LAN name,
#   Tailscale name, etc.) and do NOT use the standalone profile.
PG_HOST=db
PG_PORT=5432
PG_DB=warehouse

# Standalone mode: password for the bundled DB's postgres superuser (also
# used by the migration runner by default).
POSTGRES_SUPER_PW=change-me

# Shared-cluster mode: admin credentials for the migration runner (an account
# allowed to create roles/schemas on the cluster). Default: postgres /
# POSTGRES_SUPER_PW.
#PG_MIGRATE_USER=postgres
#PG_MIGRATE_PASSWORD=

# Standalone-only quirk: if you remap PG_PORT above, the migrate container
# still reaches the bundled db at 5432 on the compose network — override the
# migration runner's port only for a shared cluster on a nonstandard port.
#PG_MIGRATE_PORT=5432

# Per-role passwords (created by migrations)
HEALTH_OWNER_PW=change-me
HEALTH_RW_PW=change-me
HEALTH_RO_PW=change-me

# --- Google Health API (sync poller) -----------------------------------------
# From your Google Cloud project's OAuth 2.0 client (testing mode is fine
# for personal use).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Populated by the one-time auth flow; stored outside the repo.
GOOGLE_TOKEN_PATH=./secrets/google_token.json

# --- Backfill loader ----------------------------------------------------------
# Path to the extracted Fitbit Takeout export: the "Takeout" directory that
# contains "Google Health/".
TAKEOUT_DIR=./data/takeout

# Optional: extracted Google Fit Takeout export (the "Takeout" directory that
# contains "Fit/") — only useful if you have legacy data that synced to Google
# Fit (e.g. Basis Peak). Empty disables.
GOOGLEFIT_DIR=

# IANA timezone your Fitbit profile used — several Takeout streams carry naive
# local timestamps (AZM, temperature, sleep + weight JSON) that must be
# converted to UTC. See docs/takeout-format.md.
TAKEOUT_TZ=America/Los_Angeles

# Unit of the "weight" values in your export (follows your Fitbit account
# setting): lbs or kg.
TAKEOUT_WEIGHT_UNIT=lbs

# --- Grafana (standalone mode) -------------------------------------------------
# Admin password and host port for the bundled Grafana.
GRAFANA_ADMIN_PW=change-me
GRAFANA_PORT=3000

# --- Monitoring (optional) ----------------------------------------------------
# Healthchecks.io ping URL for the sync job's dead-man switch; empty disables.
HEALTHCHECKS_PING_URL=
